# TMDB API - use as Bearer token in Authorization header
# Register free at https://developer.themoviedb.org
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here

# OMDB API key
# Register free at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# Socket.io server URL (for Next.js client to connect to)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
